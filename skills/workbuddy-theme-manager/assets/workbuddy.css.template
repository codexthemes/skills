html.workbuddy-themes-host[data-workbuddy-theme="{{themeId}}"] {
  color-scheme: {{mode}} !important;
  --wbt-canvas: {{canvas}};
  --wbt-surface: {{surface}};
  --wbt-raised: {{raised}};
  --wbt-text: {{text}};
  --wbt-muted: {{muted}};
  --wbt-accent: {{accent}};
  --wbt-border: {{border}};
  --wbt-focus: {{focus}};
  --wbt-danger: {{danger}};
  --wbt-terminal-bg: {{terminalBackground}};
  --wbt-terminal-fg: {{terminalForeground}};
  --wbt-accent-soft: color-mix(in srgb, var(--wbt-accent) 16%, transparent);
  --wbt-border-soft: color-mix(in srgb, var(--wbt-border) 72%, transparent);
  --wbt-artwork: var(--workbuddy-theme-artwork, none);
}

html.workbuddy-themes-host,
html.workbuddy-themes-host body,
html.workbuddy-themes-host #root,
html.workbuddy-themes-host .teams-container {
  background: var(--wbt-canvas) !important;
  color: var(--wbt-text) !important;
}

html.workbuddy-themes-host :is(.conversation-sidebar, .conversation-list) {
  background: color-mix(in srgb, var(--wbt-surface) 94%, transparent) !important;
  border-right: 1px solid var(--wbt-border-soft) !important;
  color: var(--wbt-text) !important;
  backdrop-filter: blur(18px) saturate(1.05);
}

html.workbuddy-themes-host :is(.conversation-sidebar, .conversation-list) :is(a, button, [role="button"]) {
  border-radius: 10px !important;
  color: var(--wbt-text) !important;
}

html.workbuddy-themes-host :is(.conversation-sidebar, .conversation-list) :is(a, button, [role="button"]):hover,
html.workbuddy-themes-host :is(.conversation-sidebar, .conversation-list) :is(.active, [aria-current="page"], [aria-selected="true"]) {
  background: var(--wbt-accent-soft) !important;
}

html.workbuddy-themes-host :is(.teams-content-wrapper, .teams-main-content, .main-content, .chat-container, .wb-cb-chat) {
  background: transparent !important;
  color: var(--wbt-text) !important;
}

html.workbuddy-themes-host .wb-home-page {
  width: min(960px, calc(100% - 32px)) !important;
  max-width: none !important;
}

html.workbuddy-themes-host .wb-home-header {
  position: relative !important;
  isolation: isolate;
  min-height: 220px !important;
  overflow: hidden !important;
  border: 1px solid var(--wbt-border-soft) !important;
  border-radius: 24px !important;
  background-color: var(--wbt-raised) !important;
  background-image:
    linear-gradient(90deg, color-mix(in srgb, var(--wbt-raised) 98%, transparent) 0 38%, color-mix(in srgb, var(--wbt-raised) 76%, transparent) 62%, transparent 90%),
    var(--wbt-artwork) !important;
  background-position: center, center !important;
  background-size: cover, cover !important;
  background-repeat: no-repeat !important;
  box-shadow: 0 16px 36px color-mix(in srgb, var(--wbt-canvas) 48%, transparent) !important;
}

html.workbuddy-themes-host :is(.wb-home-header__title, .wb-home-header__subtitle) {
  position: relative;
  z-index: 1;
  width: 58% !important;
  color: var(--wbt-text) !important;
  text-align: left !important;
  text-shadow: 0 2px 16px var(--wbt-raised);
}

html.workbuddy-themes-host :is(.wb-scene-tabs, .quick-actions__item) {
  border: 1px solid var(--wbt-border-soft) !important;
  border-radius: 14px !important;
  background: var(--wbt-surface) !important;
  color: var(--wbt-text) !important;
}

html.workbuddy-themes-host :is(.wb-home-composer__input-slot > section, .chat-container section:has([role="textbox"])) {
  border: 1px solid var(--wbt-border-soft) !important;
  border-radius: 20px !important;
  background: var(--wbt-raised) !important;
  color: var(--wbt-text) !important;
  box-shadow: 0 12px 30px color-mix(in srgb, var(--wbt-canvas) 42%, transparent) !important;
}

html.workbuddy-themes-host [role="textbox"][contenteditable="true"] {
  color: var(--wbt-text) !important;
  caret-color: var(--wbt-accent) !important;
}

html.workbuddy-themes-host :is(button, [role="button"], a, input, textarea, [contenteditable="true"]):focus-visible {
  outline: 2px solid var(--wbt-focus) !important;
  outline-offset: 2px !important;
}

html.workbuddy-themes-host .chat-container:not(.chat-container--welcome) :is(table, pre, blockquote) {
  border: 1px solid var(--wbt-border-soft) !important;
  border-radius: 12px !important;
  background: var(--wbt-surface) !important;
  color: var(--wbt-text) !important;
}

html.workbuddy-themes-host .chat-container:not(.chat-container--welcome) pre {
  overflow: auto !important;
  background: var(--wbt-terminal-bg) !important;
  color: var(--wbt-terminal-fg) !important;
}

html.workbuddy-themes-host :is(a, button, input, textarea, [contenteditable="true"]) {
  accent-color: var(--wbt-accent);
}

html.workbuddy-themes-host * {
  scrollbar-color: color-mix(in srgb, var(--wbt-accent) 38%, transparent) transparent;
}

@media (max-width: 820px) {
  html.workbuddy-themes-host .wb-home-header {
    background-image: linear-gradient(color-mix(in srgb, var(--wbt-raised) 90%, transparent), color-mix(in srgb, var(--wbt-raised) 94%, transparent)), var(--wbt-artwork) !important;
  }

  html.workbuddy-themes-host :is(.wb-home-header__title, .wb-home-header__subtitle) {
    width: 100% !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  html.workbuddy-themes-host *,
  html.workbuddy-themes-host *::before,
  html.workbuddy-themes-host *::after {
    animation-duration: .01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: .01ms !important;
  }
}
